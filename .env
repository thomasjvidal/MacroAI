# Configurações do MacroAI

# Porta do servidor (padrão: 3000 ou 3002)
PORT=3003

# Chaves de API de Inteligência Artificial
# Obtenha sua chave gratuita do Gemini em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Opcional: Chave da OpenAI se preferir usar GPT
OPENAI_API_KEY=

# Opcional: Chave da Hugging Face
HF_API_KEY=
